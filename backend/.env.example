# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=limitly_db

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long
JWT_EXPIRES_IN=7d

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# App URL (for short links)
APP_URL=http://localhost:5000

# Free Plan Limit
FREE_PLAN_DAILY_LIMIT=10

# Email (for Forgot Password) — Hostinger SMTP
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_USER=helpdesk@smdigitalworks.com
EMAIL_PASS=your_hostinger_email_password
EMAIL_FROM=Limitly <helpdesk@smdigitalworks.com>

# OpenAI API Key (for Alt Text Generator)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
